name: myvento-image-generation
trigger:
  type: scheduler
  interval: 15m

modules:

  - id: airtable_search
    type: airtable.searchRecords
    config:
      table: Content Library
      formula: 'AND({Media Status}="Pending")'

  - id: iterator
    type: tools.iterator
    input: airtable_search.records

  - id: leonardo_generate
    type: http.request
    config:
      method: POST
      url: https://cloud.leonardo.ai/api/rest/v1/generations
      headers:
        Authorization: Bearer {{LEONARDO_API_KEY}}
        Content-Type: application/json
      body: |
        {
          "prompt": "{{trim(replace(iterator['Image Prompt']; '\n'; ' '))}}",
          "modelId": "b24e16ff-06e3-43eb-8d33-4416c2d75876",
          "width": 1024,
          "height": 1024,
          "num_images": 1,
          "alchemy": true,
          "photoReal": true
        }

  - id: sleep
    type: tools.sleep
    config:
      seconds: 6

  - id: leonardo_fetch
    type: http.request
    config:
      method: GET
      url: "https://cloud.leonardo.ai/api/rest/v1/generations/{{leonardo_generate.generationId}}"
      headers:
        Authorization: Bearer {{LEONARDO_API_KEY}}

  - id: airtable_update
    type: airtable.updateRecord
    config:
      table: Content Library
      recordId: "{{iterator.id}}"
      fields:
        Media URL: "{{leonardo_fetch.generated_images[1].url}}"
        Media Status: "Ready"
